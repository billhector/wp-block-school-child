{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "background": true,
      "customDuotone": true,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#0f172a",
          "name": "Primary (Slate)"
        },
        {
          "slug": "primary-light",
          "color": "#334155",
          "name": "Primary Light"
        },
        {
          "slug": "primary-dark",
          "color": "#020617",
          "name": "Primary Dark"
        },
        {
          "slug": "secondary",
          "color": "#ea580c",
          "name": "Secondary (Burnt Orange)"
        },
        {
          "slug": "secondary-light",
          "color": "#fb923c",
          "name": "Secondary Light"
        },
        {
          "slug": "secondary-dark",
          "color": "#9a3412",
          "name": "Secondary Dark"
        },
        {
          "slug": "accent",
          "color": "#14b8a6",
          "name": "Accent (Teal)"
        },
        {
          "slug": "accent-light",
          "color": "#5eead4",
          "name": "Accent Light"
        },
        {
          "slug": "accent-dark",
          "color": "#0f766e",
          "name": "Accent Dark"
        },
        {
          "slug": "text",
          "color": "#1e293b",
          "name": "Text"
        },
        {
          "slug": "text-muted",
          "color": "#475569",
          "name": "Text Muted"
        },
        {
          "slug": "background",
          "color": "#fafaf9",
          "name": "Background (Warm White)"
        },
        {
          "slug": "background-subtle",
          "color": "#f5f5f4",
          "name": "Background Subtle"
        },
        {
          "slug": "border",
          "color": "#e7e5e4",
          "name": "Border"
        },
        {
          "slug": "danger",
          "color": "#dc2626",
          "name": "Danger"
        },
        {
          "slug": "code-bg",
          "color": "#0f172a",
          "name": "Code Background"
        },
        {
          "slug": "code-text",
          "color": "#e2e8f0",
          "name": "Code Text"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "inter",
          "name": "Inter",
          "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/inter-v20-latin-regular.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "400",
              "fontStyle": "italic",
              "src": [
                "file:./assets/fonts/inter-v20-latin-italic.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "700",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/inter-v20-latin-700.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "700",
              "fontStyle": "italic",
              "src": [
                "file:./assets/fonts/inter-v20-latin-700italic.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontWeight": "900",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/inter-v20-latin-900.woff2"
              ]
            }
          ]
        },
        {
          "slug": "jetbrains-mono",
          "name": "JetBrains Mono",
          "fontFamily": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace",
          "fontFace": [
            {
              "fontFamily": "JetBrains Mono",
              "fontWeight": "400",
              "fontStyle": "normal",
              "src": [
                "file:./assets/fonts/jetbrains-mono-v24-latin-regular.woff2"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "xs",    "size": "clamp(0.75rem, 0.71rem + 0.18vw, 0.875rem)",  "name": "XS",   "fluid": false },
        { "slug": "sm",    "size": "clamp(0.875rem, 0.83rem + 0.21vw, 1rem)",      "name": "SM",   "fluid": false },
        { "slug": "base",  "size": "clamp(1rem, 0.95rem + 0.24vw, 1.125rem)",      "name": "Base", "fluid": false },
        { "slug": "lg",    "size": "clamp(1.125rem, 1.05rem + 0.36vw, 1.375rem)",  "name": "LG",   "fluid": false },
        { "slug": "xl",    "size": "clamp(1.25rem, 1.13rem + 0.59vw, 1.625rem)",   "name": "XL",   "fluid": false },
        { "slug": "2xl",   "size": "clamp(1.5rem, 1.31rem + 0.94vw, 2rem)",        "name": "2XL",  "fluid": false },
        { "slug": "3xl",   "size": "clamp(1.875rem, 1.55rem + 1.62vw, 2.625rem)",  "name": "3XL",  "fluid": false },
        { "slug": "4xl",   "size": "clamp(2.25rem, 1.78rem + 2.35vw, 3.375rem)",   "name": "4XL",  "fluid": false },
        { "slug": "5xl",   "size": "clamp(2.75rem, 2.08rem + 3.35vw, 4.25rem)",    "name": "5XL",  "fluid": false }
      ]
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        { "slug": "10", "size": "0.25rem",  "name": "1" },
        { "slug": "20", "size": "0.5rem",   "name": "2" },
        { "slug": "30", "size": "0.75rem",  "name": "3" },
        { "slug": "40", "size": "1rem",     "name": "4" },
        { "slug": "50", "size": "1.5rem",   "name": "5" },
        { "slug": "60", "size": "2rem",     "name": "6" },
        { "slug": "70", "size": "3rem",     "name": "7" },
        { "slug": "80", "size": "4rem",     "name": "8" },
        { "slug": "90", "size": "5rem",     "name": "9" },
        { "slug": "100", "size": "7rem",    "name": "10" }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "900",
          "fontSize": "var(--wp--preset--font-size--5xl)",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "lineHeight": "1.2",
          "letterSpacing": "-0.01em"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "lineHeight": "1.3"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "lineHeight": "1.3"
        },
        "color": {
          "text": "var(--wp--preset--color--text)"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--base)",
          "lineHeight": "1.4",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em"
        },
        "color": {
          "text": "var(--wp--preset--color--text-muted)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--secondary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary-dark)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--background)"
        },
        "border": {
          "radius": "4px",
          "width": "0"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "right": "var(--wp--preset--spacing--50)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--base)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-light)"
          }
        }
      }
    },
    "blocks": {
      "core/code": {
        "color": {
          "background": "var(--wp--preset--color--code-bg)",
          "text": "var(--wp--preset--color--code-text)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
          "fontSize": "var(--wp--preset--font-size--sm)"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--40)",
            "right": "var(--wp--preset--spacing--40)",
            "bottom": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--40)"
          }
        }
      },
      "core/preformatted": {
        "color": {
          "background": "var(--wp--preset--color--code-bg)",
          "text": "var(--wp--preset--color--code-text)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--jetbrains-mono)",
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      },
      "core/quote": {
        "border": {
          "left": {
            "color": "var(--wp--preset--color--secondary)",
            "width": "4px",
            "style": "solid"
          }
        },
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontStyle": "normal"
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--border)"
        }
      }
    }
  }
}
